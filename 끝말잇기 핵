local function getCompatibleChars(char)
    local map = {
        ["피"] = {"피", "픠"}, ["픠"] = {"피", "픠"},
        ["두"] = {"두", "디"}, ["디"] = {"두", "디"},
        ["분"] = {"분", "비"}, ["비"] = {"분", "비"},
        ["귀"] = {"귀", "기"}, ["기"] = {"귀", "기"},
        ["미"] = {"미", "믜"}, ["믜"] = {"미", "믜"},
        ["남"] = {"남", "내"}, ["내"] = {"남", "내"},
        ["우"] = {"우", "의"}, ["의"] = {"우", "의"},
        ["투"] = {"투", "티"}, ["티"] = {"투", "티"},
        ["류"] = {"류", "라"}, ["라"] = {"류", "라"},
        ["뇰"] = {"욜"}
    }
    return map[char] or {char}
end

