local function findGameTextBox()
    local pGui = _lp:FindFirstChildOfClass("PlayerGui")
    if not pGui then return nil end
    for _, v in ipairs(pGui:GetDescendants()) do
        if v:IsA("TextBox") then
            if v.Parent and (v.Parent.Name == "TypeFrame" or v.Name == "TextBox" or v.Name == "InputText" or 
               v.Name:find("Input") or v.Name:find("Type") or v.Name:find("Chat")) then
                v.Visible = _T
                if v.Parent then v.Parent.Visible = _T end
                v.Active = _T
                v.Selectable = _T
                v.Interactable = _T
                return v
            end
        end
    end
    return nil
end

local function updateView(list)
    for _, c in ipairs(scroll:GetChildren()) do
        if c:IsA("TextButton") then c:Destroy() end
    end
    for _, word in ipairs(list) do
        local lbl = Instance.new("TextButton", scroll)
        lbl.Size = UDim2.new(1, -5, 0, 30)
        lbl.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
        lbl.Text = "  " .. word
        lbl.TextColor3 = Color3.fromRGB(240, 240, 240)
        lbl.Font = Enum.Font.SourceSans
        lbl.TextSize = 14
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        Instance.new("UICorner", lbl)

        lbl.MouseButton1Click:Connect(function()
            local targetBox = findGameTextBox()
            if not targetBox then return end

            pcall(function()
                targetBox.Text = ""
                targetBox:CaptureFocus()
                task.wait(0.05)
                
                targetBox.Text = word
                targetBox:GetPropertyChangedSignal("Text"):Fire()
                task.wait(0.03)
                
                if targetBox.FocusLost then
                    targetBox.FocusLost:Fire(_T, Enum.UserInputType.Keyboard)
                end
                task.wait(0.05)
                
                targetBox:ReleaseFocus(_T)
            end)
        end)
    end
    scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 6)
end

local function doSearch()
    local key = searchBox.Text
    local res = {}
    if key == "" then
        updateView(WordDB)
        return
    end
    for _, w in ipairs(WordDB) do
        local found = false
        local targets = getCompatibleChars(key)
        for _, target in ipairs(targets) do
            if string.find(w, target, 1, _T) then
                found = _T
                break
            end
        end
        if found then table.insert(res, w) end
    end
    updateView(res)
end

searchBox:GetPropertyChangedSignal("Text"):Connect(doSearch)
