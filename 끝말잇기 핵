-- ==========================================
-- 제시어 시스템 실시간 트래킹 루프
-- ==========================================
local _lt = ""
local function findSpectatorLabel()
    local pGui = _lp:FindFirstChildOfClass("PlayerGui")
    if not pGui then return nil end
    for _, v in ipairs(pGui:GetDescendants()) do
        if v:IsA("TextLabel") and (v.Name == "SpectatorTipLabel" or v.Text:find("시작하는")) then
            return v
        end
    end
    return nil
end

local function findTurnTime()
    local pGui = _lp:FindFirstChildOfClass("PlayerGui")
    if not pGui then return "" end
    for _, v in ipairs(pGui:GetDescendants()) do
        if v:IsA("TextLabel") and v.Text and v.Text ~= "" then
            -- 차례 및 실시간 초단위 완벽 매칭 정규식 수리
            local matched = string.match(v.Text, "(%[%d+초%])") or string.match(v.Text, "의 차례%s*(%[%d+초%])")
            if matched then
                return " / " .. matched
            end
        end
    end
    return ""
end

task.spawn(function()
    while task.wait(0.15) do
        local targetLabel = findSpectatorLabel()
        local currentTime = findTurnTime()

        if not targetLabel then
            if frame.Visible then 
                title.Text = " 🔍 탐색 중..." .. currentTime 
            end
            continue
        end

        local text = targetLabel.Text
        local ch = ""
        pcall(function()
            ch = string.match(text, "'(.-)'") or string.match(text, '"(.-)"') or string.match(text, "([가-힣])")
        end)

        if ch and ch ~= "" and utf8.len(ch) == 1 then
            if ch ~= _lt then
                _lt = ch
                searchBox.Text = ch
            end
            if frame.Visible then 
                title.Text = " ⚡ 글자: '" .. ch .. "'" .. currentTime 
            end
        elseif frame.Visible then
            title.Text = " ⏳ 대기 중" .. currentTime
        end
    end
end)

